PORT=5001

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Supabase Postgres (Prisma): pooler for runtime, direct for migrations
DATABASE_URL=
DIRECT_URL=

# HS256 secret for admin JWTs (must match issuer of admin tokens)
ADMIN_JWT_SECRET=dev-secret-change-me-use-long-random-string

# Set to 1 to log incoming HTTP requests (dev only)
REQUEST_LOGGING=1

