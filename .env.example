PORT=5001

# Comma-separated browser origins allowed for credentialed CORS (cookies, fetch credentials).
# Any origin not in this list is rejected. Defaults to http://localhost:3000 when unset.
# Example: CORS_ORIGINS=http://localhost:3000,https://app.example.com
# CORS_ORIGINS=

# Public API origin for OpenAPI/Swagger "Try it out" (no trailing slash). On Render, RENDER_EXTERNAL_URL is set automatically; override with PUBLIC_API_URL for a custom domain.
PUBLIC_API_URL=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay webhook signing secret (Dashboard → Webhooks). Required for POST /api/v1/billing/webhooks/razorpay.
# Server logs JSON lines with "scope":"billing.webhook" (ingress → verified → processed).
# Razorpay sends X-Razorpay-Event-Id per delivery; the handler uses it when the JSON body has no root "id".
RAZORPAY_WEBHOOK_SECRET=

# Billing: amount limits in major units; comma-separated ISO 4217 codes
BILLING_MIN_AMOUNT_MAJOR=1
# Max per cycle in major units (default 124200 ≈ $124,200 when pricing in whole dollars)
BILLING_MAX_AMOUNT_MAJOR=124200
BILLING_ALLOWED_CURRENCIES=INR,USD
# Razorpay subscription total billing cycles (default 120)
BILLING_DEFAULT_TOTAL_COUNT=120
DATABASE_URL=
DIRECT_URL=

# Postgres driver adapter (pg) pool tuning. Defaults are sensible for dev.
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000
DB_POOL_CONN_TIMEOUT_MS=5000

# Set to "false" to skip TLS cert verification (e.g. self-signed Postgres in CI).
# Leave unset for managed providers like Supabase / RDS where certs are valid.
DATABASE_SSL_REJECT_UNAUTHORIZED=

# HS256 secret for admin JWTs (POST /api/v1/auth/admin-signin-referral, admin-signup-referral)
ADMIN_JWT_SECRET=dev-secret-change-me-use-long-random-string

# HS256 secret for dashboard user JWTs (POST /api/v1/auth/signin-referral, signup-referral)
USER_JWT_SECRET=dev-user-secret-change-me-use-long-random-string

# --- Referral auth (email + password → demo_users / demo_admins) ---
# User: POST /api/v1/auth/signup-referral, POST /api/v1/auth/signin-referral
# Admin: POST /api/v1/auth/admin-signup-referral, POST /api/v1/auth/admin-signin-referral
# Passwords are stored plaintext in DB for now — hash before production (see TODOs in referralAuthService).
# Optional HttpOnly cookie names (defaults doublle_access_token / doublle_admin_access_token):
# USER_ACCESS_TOKEN_COOKIE_NAME=
# ADMIN_ACCESS_TOKEN_COOKIE_NAME=

# Fraud signal thresholds (flag-only; admin review via GET /api/v1/admin/referrals/:id).
# REFERRAL_FRAUD_VELOCITY_24H=10
# REFERRAL_FRAUD_HIGH_COMMISSION_MAJOR=1000

# Shared secret for POST /api/v1/internal/commissions/* (cron: transition-earned, apply-credit).
# Send header X-Internal-Cron-Secret with the same value. See docs/COMMISSION_LIFECYCLE.md.
INTERNAL_CRON_SECRET=

# Set to 1 to log incoming HTTP requests (dev only)
REQUEST_LOGGING=1
