PORT=5001

# Comma-separated browser origins allowed for credentialed CORS (cookies, fetch credentials).
# Any origin not in this list is rejected. Defaults to http://localhost:3000 when unset.
# Example: CORS_ORIGINS=http://localhost:3000,https://app.example.com
# CORS_ORIGINS=

# Public API origin for OpenAPI/Swagger "Try it out" (no trailing slash). On Render, RENDER_EXTERNAL_URL is set automatically; override with PUBLIC_API_URL for a custom domain.
PUBLIC_API_URL=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay webhook signing secret (Dashboard → Webhooks). Required for POST /api/v1/billing/webhooks/razorpay.
# Server logs JSON lines with "scope":"billing.webhook" (ingress → verified → processed).
# Razorpay sends X-Razorpay-Event-Id per delivery; the handler uses it when the JSON body has no root "id".
RAZORPAY_WEBHOOK_SECRET=

# Billing: amount limits in major units; comma-separated ISO 4217 codes
BILLING_MIN_AMOUNT_MAJOR=1
# Max per cycle in major units (default 124200 ≈ $124,200 when pricing in whole dollars)
BILLING_MAX_AMOUNT_MAJOR=124200
BILLING_ALLOWED_CURRENCIES=INR,USD
# Razorpay subscription total billing cycles (default 120)
BILLING_DEFAULT_TOTAL_COUNT=120
DATABASE_URL=
DIRECT_URL=

# Postgres driver adapter (pg) pool tuning. Defaults are sensible for dev.
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000
DB_POOL_CONN_TIMEOUT_MS=5000

# Set to "false" to skip TLS cert verification (e.g. self-signed Postgres in CI).
# Leave unset for managed providers like Supabase / RDS where certs are valid.
DATABASE_SSL_REJECT_UNAUTHORIZED=

# HS256 secrets for admin JWTs (any listed secret may sign valid admin tokens; demo: three admins / three keys)
ADMIN_JWT_SECRET=dev-secret-change-me-use-long-random-string
ADMIN_JWT_SECRET_2=dev-secret-admin-2-change-me-use-long-random-string
ADMIN_JWT_SECRET_3=dev-secret-admin-3-change-me-use-long-random-string

# HS256 secrets for dashboard user JWTs (any listed secret may sign valid user tokens; demo: three users / three keys)
USER_JWT_SECRET=dev-user-secret-change-me-use-long-random-string
USER_JWT_SECRET_2=dev-user-secret-2-change-me-use-long-random-string
USER_JWT_SECRET_3=dev-user-secret-3-change-me-use-long-random-string

# --- Optional: passwordless demo user login (no passwords) ---
# POST /api/v1/auth/demo with JSON body `{ "email": "..." }` is registered only when DEMO_AUTH_ENABLED=true
# and NODE_ENV is not production, unless you set DEMO_AUTH_ALLOW_PRODUCTION=true (explicit prod opt-in).
# Allowlisted emails live in Postgres table `demo_users` (see prisma/migrations). Create/update rows via
# GET/POST/PATCH/DELETE /api/v1/admin/demo-users (admin JWT) or direct SQL. Only rows with is_enabled=true
# receive a JWT. Tokens use USER_JWT_SECRET, HS256, payload { sub, role: "user", email }, exp 24h.
# Optional: override the HttpOnly cookie name used for that JWT (default doublle_access_token).
# USER_ACCESS_TOKEN_COOKIE_NAME=
DEMO_AUTH_ENABLED=false
# Set to true only if you intentionally run passwordless demo JWT mint in production (not recommended).
DEMO_AUTH_ALLOW_PRODUCTION=false

# Public app base URL for ?ref= referral links (POST /api/v1/referral/terms/accept). Required; no default.
REFERRAL_PUBLIC_BASE_URL=

# Set to 1 to log incoming HTTP requests (dev only)
REQUEST_LOGGING=1
