generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum AttributionRule {
  FIRST_TOUCH
  FIRST_TOUCH_CODE_OVERRIDE
  LAST_TOUCH
}

enum RefereeBenefitType {
  NONE
  TRIAL_EXTENSION
  CREDIT
}

enum CapBehavior {
  ROLL_FORWARD
  HARD_STOP
}

enum ReferralStatus {
  ACTIVE
  TERMINATED
  FRAUD_REJECTED
}

enum AttributionSource {
  LINK
  MANUAL_CODE
  COOKIE
  BOTH
}

enum CommissionState {
  PENDING
  EARNED
  PAID
  CLAWED_BACK
}

model Program {
  id                        String             @id @default(uuid()) @db.Uuid
  name                      String             @db.VarChar(255)
  status                    ProgramStatus      @default(DRAFT)
  rewardPct                 Decimal            @map("reward_pct") @db.Decimal(5, 2)
  rewardDurationMonths      Int                @map("reward_duration_months")
  cookieDays                Int                @map("cookie_days")
  attributionRule           AttributionRule    @map("attribution_rule")
  refereeBenefitType        RefereeBenefitType @map("referee_benefit_type")
  refereeBenefitValue       Decimal?           @map("referee_benefit_value") @db.Decimal(12, 2)
  refereeBenefitTrialDays   Int?               @map("referee_benefit_trial_days")
  holdPeriodDays            Int                @map("hold_period_days")
  monthlyCap                Decimal?           @map("monthly_cap") @db.Decimal(12, 2)
  lifetimeCap               Decimal?           @map("lifetime_cap") @db.Decimal(12, 2)
  capBehavior               CapBehavior        @map("cap_behavior")
  refereeMinSpendAmount     Decimal?           @map("referee_min_spend_amount") @db.Decimal(12, 2)
  refereeMinSpendWindowDays Int?               @map("referee_min_spend_window_days")
  currency                  String             @default("USD") @db.VarChar(3)
  termsVersion              String             @map("terms_version") @db.VarChar(64)
  currentVersion            Int                @default(1) @map("current_version")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")
  createdByAdminId          String?            @map("created_by_admin_id") @db.VarChar(255)
  disabledAt                DateTime?          @map("disabled_at")

  versions ProgramVersion[]

  referralTermsAcceptances ReferralTermsAcceptance[]
  referralCodes            ReferralCode[]
  referrals                Referral[]

  @@index([status])
  @@index([name])
  @@map("programs")
}

model ReferralTermsAcceptance {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.VarChar(255)
  programId    String   @map("program_id") @db.Uuid
  termsVersion String   @map("terms_version") @db.VarChar(64)
  acceptedAt   DateTime @default(now()) @map("accepted_at")
  ip           String   @map("ip") @db.VarChar(45)

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId, termsVersion])
  @@index([userId, programId])
  @@map("referral_terms_acceptances")
}

model ReferralCode {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.VarChar(255)
  programId   String   @map("program_id") @db.Uuid
  code        String   @unique @db.VarChar(16)
  createdAt   DateTime @default(now()) @map("created_at")

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, programId])
  @@index([code])
  @@map("referral_codes")
}

/// Attribution of a referee to a referrer under a program (code snapshot + attribution metadata).
model Referral {
  id                           String            @id @default(uuid()) @db.Uuid
  refereeUserId                String            @map("referee_user_id") @db.VarChar(255)
  referrerUserId               String            @map("referrer_user_id") @db.VarChar(255)
  programId                    String            @map("program_id") @db.Uuid
  code                         String            @db.VarChar(16)
  status                       ReferralStatus    @default(ACTIVE)
  attributionSource            AttributionSource @map("attribution_source")
  cookieData                   Json?             @map("cookie_data")
  ip                           String?           @db.VarChar(45)
  userAgent                    String?           @map("user_agent") @db.Text
  programVersionAtAttribution  Int               @map("program_version_at_attribution")
  terminatedAt                 DateTime?         @map("terminated_at")
  terminationReason            String?           @map("termination_reason") @db.Text
  refereeCreditApplied         Boolean           @default(false) @map("referee_credit_applied")
  refereeCreditAppliedAt       DateTime?         @map("referee_credit_applied_at")
  createdAt                    DateTime          @default(now()) @map("created_at")
  updatedAt                    DateTime          @updatedAt @map("updated_at")

  program      Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  commissions  Commission[]
  fraudSignals FraudSignal[]

  @@unique([refereeUserId, programId])
  @@index([referrerUserId, programId])
  @@index([programId])
  @@index([code])
  @@index([status])
  @@index([createdAt])
  @@map("referrals")
}

/// Referral commission accrual and lifecycle (pending → earned → paid / clawed back).
model Commission {
  id                   String          @id @default(uuid()) @db.Uuid
  referralId           String          @map("referral_id") @db.Uuid
  sourcePaymentId      String?         @map("source_payment_id") @db.Uuid
  sourceInvoiceId      String?         @map("source_invoice_id") @db.VarChar(64)
  grossAmount          Decimal         @map("gross_amount") @db.Decimal(12, 2)
  netAmount            Decimal         @map("net_amount") @db.Decimal(12, 2)
  rewardPct            Decimal         @map("reward_pct") @db.Decimal(5, 2)
  commissionAmount     Decimal         @map("commission_amount") @db.Decimal(12, 2)
  currency             String          @db.VarChar(3)
  state                CommissionState @default(PENDING)
  accruedAt            DateTime        @map("accrued_at")
  payableAt            DateTime?       @map("payable_at")
  paidAt               DateTime?       @map("paid_at")
  clawbackReason       String?         @map("clawback_reason") @db.Text
  reversesCommissionId String?         @map("reverses_commission_id") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at")

  referral           Referral             @relation(fields: [referralId], references: [id], onDelete: Restrict)
  sourcePayment      SubscriptionPayment? @relation(fields: [sourcePaymentId], references: [id], onDelete: SetNull)
  reversesCommission Commission?          @relation("CommissionReversal", fields: [reversesCommissionId], references: [id], onDelete: SetNull)
  reversedBy         Commission[]         @relation("CommissionReversal")

  @@unique([sourcePaymentId])
  @@index([referralId])
  @@index([state])
  @@index([accruedAt])
  @@map("commissions")
}

/// Fraud signal recorded against a referral for review-queue and auto-block rules.
model FraudSignal {
  id         String   @id @default(uuid()) @db.Uuid
  referralId String   @map("referral_id") @db.Uuid
  type       String   @db.VarChar(128)
  score      Decimal  @db.Decimal(6, 4)
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Restrict)

  @@index([referralId])
  @@index([createdAt])
  @@map("fraud_signals")
}

model ProgramVersion {
  id                 String   @id @default(uuid()) @db.Uuid
  programId          String   @map("program_id") @db.Uuid
  version            Int
  payload            Json
  changedByAdminId   String   @map("changed_by_admin_id") @db.VarChar(255)
  changeReason       String?  @map("change_reason") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, version])
  @@index([programId])
  @@map("program_versions")
}

model AdminAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.VarChar(255)
  action     String   @db.VarChar(128)
  targetType String   @map("target_type") @db.VarChar(64)
  targetId   String   @map("target_id") @db.VarChar(64)
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@map("admin_audit_logs")
}

enum BillingFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum SubscriptionStatus {
  CREATED
  AUTHENTICATED
  ACTIVE
  PENDING
  HALTED
  PAUSED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum SubscriptionPaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

model BillingCustomer {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @unique @map("user_id") @db.VarChar(255)
  razorpayCustomerId String         @unique @map("rzp_customer_id") @db.VarChar(64)
  email              String?        @db.VarChar(255)
  createdAt          DateTime       @default(now()) @map("created_at")
  subscriptions      Subscription[]

  @@map("billing_customers")
}

model BillingPlan {
  id               String           @id @default(uuid()) @db.Uuid
  razorpayPlanId   String           @unique @map("rzp_plan_id") @db.VarChar(64)
  amountMinor      Int              @map("amount_minor")
  currency         String           @db.VarChar(3)
  frequency        BillingFrequency
  period           String           @db.VarChar(16)
  interval         Int
  createdAt        DateTime         @default(now()) @map("created_at")
  subscriptions    Subscription[]

  @@unique([amountMinor, currency, frequency])
  @@map("billing_plans")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @map("user_id") @db.VarChar(255)
  customerId         String             @map("customer_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  razorpaySubId      String             @unique @map("rzp_subscription_id") @db.VarChar(64)
  status             SubscriptionStatus
  amountMinor        Int                @map("amount_minor")
  currency           String             @db.VarChar(3)
  frequency          BillingFrequency
  totalCount         Int                @map("total_count")
  paidCount          Int                @default(0) @map("paid_count")
  currentStart       DateTime?          @map("current_start")
  currentEnd         DateTime?          @map("current_end")
  nextChargeAt       DateTime?          @map("next_charge_at")
  cancelledAt        DateTime?          @map("cancelled_at")
  cancelAtCycleEnd   Boolean            @default(false) @map("cancel_at_cycle_end")
  shortUrl           String?            @map("short_url") @db.Text
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  customer BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  plan     BillingPlan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments SubscriptionPayment[]

  @@index([userId, status])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id                String                    @id @default(uuid()) @db.Uuid
  subscriptionId    String                    @map("subscription_id") @db.Uuid
  razorpayPaymentId String                    @unique @map("rzp_payment_id") @db.VarChar(64)
  razorpayOrderId   String?                   @map("rzp_order_id") @db.VarChar(64)
  razorpayInvoiceId String?                   @map("rzp_invoice_id") @db.VarChar(64)
  amountMinor       Int                       @map("amount_minor")
  currency          String                    @db.VarChar(3)
  status            SubscriptionPaymentStatus
  method            String?                   @db.VarChar(32)
  errorCode         String?                   @map("error_code") @db.VarChar(128)
  errorDescription  String?                   @map("error_description") @db.Text
  capturedAt        DateTime?                 @map("captured_at")
  createdAt         DateTime                  @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  commissions    Commission[]

  @@index([subscriptionId])
  @@map("subscription_payments")
}

model WebhookEvent {
  id               String    @id @default(uuid()) @db.Uuid
  provider         String    @db.VarChar(32)
  eventId          String    @unique @map("event_id") @db.VarChar(64)
  eventType        String    @map("event_type") @db.VarChar(96)
  payload          Json
  receivedAt       DateTime  @default(now()) @map("received_at")
  processedAt      DateTime? @map("processed_at")
  processingError  String?   @map("processing_error") @db.Text

  @@index([eventType])
  @@map("webhook_events")
}

model DemoUser {
  id        String   @id @default(uuid()) @db.Uuid
  sub       String   @unique @db.VarChar(256)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String?  @db.VarChar(200)
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email, isEnabled])
  @@map("demo_users")
}

model DemoAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  sub       String   @unique @db.VarChar(256)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String?  @db.VarChar(200)
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email, isEnabled])
  @@map("demo_admins")
}
